# ============================================================
# eBay Card Lister — Environment Variables
# ============================================================
# Copy this file to .env and fill in the values.
# NEVER commit your actual .env file to version control.
# ============================================================

# ============================================================
# DATABASE (Neon PostgreSQL)
# ============================================================
DATABASE_URL="postgresql://user:password@host/database?sslmode=require"

# ============================================================
# JWT AUTHENTICATION
# ============================================================
JWT_SECRET="change-this-to-a-random-64-char-string"
JWT_REFRESH_SECRET="change-this-to-another-random-64-char-string"
JWT_EXPIRY="1h"
JWT_REFRESH_EXPIRY="7d"

# ============================================================
# EBAY API (Production)
# Get keys at: https://developer.ebay.com/join
# ============================================================
EBAY_CLIENT_ID="your-ebay-client-id"
EBAY_CLIENT_SECRET="your-ebay-client-secret"
EBAY_RU_NAME="your-ebay-ru-name"
EBAY_ENVIRONMENT="production"

# ============================================================
# EBAY API (Sandbox — for development)
# ============================================================
EBAY_SANDBOX_CLIENT_ID="your-ebay-sandbox-client-id"
EBAY_SANDBOX_CLIENT_SECRET="your-ebay-sandbox-client-secret"
EBAY_SANDBOX_RU_NAME="your-ebay-sandbox-ru-name"

# ============================================================
# OPENAI (GPT-4o for Vision)
# Get key at: https://platform.openai.com/api-keys
# ============================================================
OPENAI_API_KEY="sk-..."

# ============================================================
# STRIPE
# Get keys at: https://dashboard.stripe.com/apikeys
# ============================================================
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_PUBLISHABLE_KEY="pk_test_..."

# ============================================================
# LISTING FEES (Stripe Price IDs — create these in Stripe Dashboard)
# ============================================================
STRIPE_PRICE_LISTING_FEE="price_..."        # $2.50
STRIPE_PRICE_RELIST_FEE="price_..."         # $1.00

# ============================================================
# SMS NOTIFICATIONS (Twilio)
# Optional — enables SMS for sold/ended alerts
# ============================================================
TWILIO_ACCOUNT_SID="AC..."
TWILIO_AUTH_TOKEN="..."
TWILIO_PHONE_NUMBER="+1234567890"

# ============================================================
# EMAIL (Resend)
# Get key at: https://resend.com/api-keys
# ============================================================
RESEND_API_KEY="re_..."
EMAIL_FROM="listings@ebaycardlister.com"
EMAIL_FROM_NAME="eBay Card Lister"

# ============================================================
# APPLICATION
# ============================================================
FRONTEND_URL="http://localhost:5173"
BACKEND_URL="http://localhost:3001"
PORT=3001
NODE_ENV="development"

# ============================================================
# REDIS (for BullMQ job queue)
# ============================================================
REDIS_URL="redis://localhost:6379"

# ============================================================
# SENTRY (optional — error tracking)
# ============================================================
# SENTRY_DSN="https://...@sentry.io/..."
